{
  "name": "nukeflame/webmatics",
  "description": "Web analyzer and optimizer",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "nukeflame"
    }
  ],
  "require": {
    "php": "^8.1",
    "bensampo/laravel-enum": "^6.12"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Nukeflame\\Webmatics\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nukeflame\\Webmatics\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nukeflame\\Webmatics\\WebmaticsServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
}
