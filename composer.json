{
    "name": "nukeflame/webmatics",
    "description": "Web analyzer and optimizer",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "nukeflame"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nukeflame\\Webmatics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nukeflame\\Webmatics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nukeflame\\Webmatics\\AnalyzerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
